{
  "name": "liquid-torrent",
  "version": "1.3.0",
  "description": "Liquid Torrent — Premium Torrent Client by DmitryMX",
  "main": "./out/main/index.js",
  "author": "Максимов Д.А. <@dmitrymx>",
  "homepage": "https://mxmvdev.ru",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder --win",
    "dist:portable": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "electron-vite": "^5.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "lucide-react": "^0.475.0",

    "zustand": "^5.0.5",
    "vite": "^6.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.15",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.5",

    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "ru.mxmvdev.liquidtorrent",
    "productName": "Liquid Torrent",
    "copyright": "Copyright © 2026 Максимов Д.А. — mxmvdev.ru",
    "npmRebuild": false,
    "asar": true,
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "scripts/dist/torrent_sidecar.exe",
        "to": "torrent_sidecar.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "resources/icon.ico",
      "fileAssociations": [
        {
          "ext": "torrent",
          "name": "Torrent File",
          "description": "BitTorrent File",
          "icon": "resources/torrent-file.ico",
          "role": "Viewer"
        }
      ]
    },
    "portable": {
      "artifactName": "LiquidTorrent-${version}-portable.exe"
    },
    "protocols": [
      {
        "name": "Magnet Link",
        "schemes": ["magnet"]
      }
    ]
  }
}
